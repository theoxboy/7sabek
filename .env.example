APP_NAME=Floussy
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://floussy:floussy@localhost:5432/floussy
JWT_SECRET=  # REQUIRED: generate with `openssl rand -hex 32`
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=30
REFRESH_TOKEN_EXP_DAYS=14
COOKIE_SECURE=true
MAIL_PROVIDER=mailtrap
MAILTRAP_API_TOKEN=  # REQUIRED in prod when MAIL_PROVIDER=mailtrap
MAIL_FROM=noreply@floussy.online
APP_BASE_URL=https://7sabek.ma
ENABLE_PASSKEYS=false
PASSKEYS_ALLOW_ALL=false
PASSKEYS_ALLOWED_EMAILS=admin@example.com
PASSKEY_RP_ID=7sabek.ma
PASSKEY_RP_ORIGIN=https://7sabek.ma
PASSKEY_ALLOWED_ORIGINS=https://7sabek.ma,https://www.7sabek.ma
PASSKEY_DEBUG_ERRORS=false
PASSKEY_RP_NAME=7sabek
PASSKEY_CHALLENGE_TTL_SECONDS=300
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=5
PASSWORD_RESET_DELIVERY_RETRIES=3
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_CURRENCY=MAD
SUPERADMIN_SWEEP_INTERVAL_DAYS=30
SUPERADMIN_PASSWORD_RESET_CODE=4303
SUPERADMIN_PASSWORD_RESET_FIRST_NAME=OMAR
RECAPTCHA_SECRET_KEY=  # REQUIRED in prod
RECAPTCHA_ENABLED=true
EMAIL_CENTER_ENABLED=false
EMAIL_CENTER_MODE=test_only
EMAIL_CENTER_KILL_SWITCH=false
EMAIL_CENTER_AI_SUGGESTIONS_ENABLED=false
EMAIL_CENTER_TEMPLATES_ENABLED=false
EMAIL_CENTER_ALLOW_BULK_SEND=false
EMAIL_CENTER_ALLOW_USER_SEND=false
EMAIL_CENTER_ALLOW_SCHEDULING=false
EMAIL_CENTER_ALLOW_SALARY_REMINDERS=false
EMAIL_CENTER_ALLOW_OPEN_TRACKING=false
EMAIL_CENTER_ALLOW_CLICK_TRACKING=false
EMAIL_CENTER_RECIPIENT_PREVIEW_ENABLED=false
EMAIL_CENTER_CAMPAIGNS_ENABLED=false
EMAIL_CENTER_CAMPAIGN_TEST_SEND_ENABLED=false
EMAIL_CENTER_PREFERENCES_ENABLED=false
EMAIL_CENTER_SUPPRESSION_ENABLED=false
EMAIL_CENTER_UNSUBSCRIBE_TOKEN_TTL_DAYS=30
EMAIL_CENTER_BULK_MAX_RECIPIENTS=100
EMAIL_CENTER_BULK_REQUIRE_TEST_SEND=true
EMAIL_CENTER_BULK_REQUIRE_DRY_RUN=true
EMAIL_CENTER_BULK_CONFIRMATION_TEXT=SEND
EMAIL_CENTER_DELIVERY_QUEUE_ENABLED=false
EMAIL_CENTER_QUEUE_BATCH_SIZE=20
EMAIL_CENTER_QUEUE_MAX_ATTEMPTS=3
EMAIL_CENTER_QUEUE_RETRY_DELAY_MINUTES=30
EMAIL_CENTER_QUEUE_RATE_LIMIT_PER_MINUTE=50
EMAIL_CENTER_TEST_RECIPIENT_EMAIL=
REGISTRATION_LEADS_ENABLED=false
REGISTRATION_LEADS_CAPTURE_EMAIL_ON_BLUR=true
REGISTRATION_LEADS_RETENTION_DAYS=90
